# Database
DB_URL=jdbc:postgresql://localhost:5432/vaultpay
DB_USERNAME=vaultpay
DB_PASSWORD=vaultpay

# JWT (RS256) — use PEM file paths or inline PEM (production: generate unique keys, never commit)
JWT_PRIVATE_KEY_LOCATION=classpath:jwt/dev-private.pem
JWT_PUBLIC_KEY_LOCATION=classpath:jwt/dev-public.pem
# Or inline (escape newlines as \n):
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
