# Database
DB_URL=jdbc:postgresql://localhost:5432/vaultpay
DB_USERNAME=vaultpay
DB_PASSWORD=vaultpay

# JWT (RS256) — private key only required; public key is derived for verification
# Generate: ./scripts/generate-jwt-keys.sh
JWT_PRIVATE_KEY_LOCATION=
# Or inline PEM (use \n for line breaks):
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
